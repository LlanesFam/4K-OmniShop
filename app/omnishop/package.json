{
  "name": "omnishop",
  "version": "1.1.5",
  "description": "OmniShop — cross-platform store manager (Tauri + React + Vite).",
  "author": "Mika",
  "homepage": "https://electron-vite.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LlanesFam/4K-OmniShop.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:debug": "tauri build --debug",
    "build:android": "tauri android build",
    "build:ios": "tauri ios build",
    "vite:dev": "vite --config vite.config.ts",
    "vite:build": "vite build --config vite.config.ts",
    "release:patch": "npm version patch && git push origin develop && git push origin --tags",
    "release:minor": "npm version minor && git push origin develop && git push origin --tags",
    "release:major": "npm version major && git push origin develop && git push origin --tags"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.2",
    "@radix-ui/react-select": "^2.2.6",
    "@sanity/client": "^7.16.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "eslint-config-prettier": "^10",
    "typescript-eslint": "^8",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase": "^12.10.0",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-easy-crop": "^5.5.6",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  }
}
