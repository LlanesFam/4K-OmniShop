{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default OmniShop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-size",
    "core:window:allow-set-decorations",
    "process:default",
    "shell:allow-open",
    "updater:default",
    "store:default",
    "notification:default"
  ]
}
